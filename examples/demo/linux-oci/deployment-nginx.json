{
  "kind": "Deployment",
  "metadata": {
    "name": "nginx-edge",
    "namespace": "default",
    "labels": { "app": "nginx", "tier": "edge" }
  },
  "spec": {
    "replicas": 2,
    "selector": { "app": "nginx" },
    "template": {
      "metadata": { "labels": { "app": "nginx", "tier": "edge" } },
      "spec": {
        "containers": [
          {
            "name": "nginx",
            "image": "nginx:alpine",
            "ports": [{ "container_port": 80 }],
            "resources": { "memory": 67108864, "cpu": 100 }
          }
        ],
        "restart_policy": "Always"
      }
    }
  }
}
