# Compiled binaries (root-anchored so they don't shadow paths like
# web/public/sprites/sheep/ — a bare "sheep" pattern matches any such dir)
/sheep
/sheepctl
/shepherd
bin/

# OS files
.DS_Store

# IDE
.idea/
.vscode/
*.swp
*.swo

# Dashboard SPA build artifacts copied over the embedded placeholder.
# Keep the committed placeholder index.html (and an optional .gitkeep) tracked;
# ignore everything else copied in from web/dist at build time.
internal/dashboard/static/*
!internal/dashboard/static/index.html
!internal/dashboard/static/.gitkeep
